# ── verify/manifest.env ────────────────────────────────────────────────
# Command-driven manifest consumed by e2e-verify.
# MODE sets which stack variant to run (compose = Docker Compose full stack).
# UP/DOWN/READY/LOGS commands control the full stack via docker compose.
# ACCEPTANCE runs the black-box test suite.
# TEST_DEPS installs pytest + httpx (NO app deps — black-box only).
# Values with spaces MUST be single-quoted (this file is `source`d by e2e-verify).

MODE=compose
PORT=8010

# Stack lifecycle
UP=docker compose up --build -d --wait
DOWN=docker compose down -v --remove-orphans

# Readiness probe — must return HTTP 200
READY=curl -sf http://localhost:${PORT}/healthz

# Log capture (for debugging failures)
LOGS=docker compose logs --tail=200

# Acceptance test deps — black-box only (HTTP client + pytest)
TEST_DEPS='httpx pytest'

# Acceptance command — runs the black-box suite
ACCEPTANCE=API_BASE_URL=http://localhost:${PORT} python -m pytest verify/acceptance/ -v --tb=short
