# --- Database ---
# PostgreSQL connection URL (async SQLAlchemy + asyncpg)
# Format: postgresql+asyncpg://<user>:<pass>@<host>:<port>/<db>
# DATABASE_URL=postgresql+asyncpg://chess:chess@localhost:5432/chess_mvp

# --- App runtime ---
# Port the uvicorn server listens on inside the container. Default: 8000
# APP_PORT=8000

# Number of async database pool connections. Default: 10
# DB_POOL_SIZE=10

# Max idle seconds before a DB connection is recycled. Default: 300
# DB_MAX_IDLE_SECONDS=300

# --- Docker Compose (host mapping) ---
# Overrides the host-mapped port for the app container. Default: 8010
# APP_PORT=8010

# --- Testing ---
# Base URL for black-box acceptance tests. Default: http://localhost:8001
# API_BASE_URL=http://localhost:8001
