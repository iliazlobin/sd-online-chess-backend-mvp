# --- Database ---
# PostgreSQL connection URL (async SQLAlchemy + asyncpg)
# Format: postgresql+asyncpg://<user>:<pass>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://chess:chess@localhost:5433/chess_mvp

# --- App ---
# Port the app listens on (inside container). Default: 8000
# APP_PORT=8000

# --- Docker Compose ---
# Overrides the host-mapped port for the app container. Default: 8010
# APP_PORT=8010
